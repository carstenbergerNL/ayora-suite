{
  "ConnectionStrings": {
    "Default": "Server=YOUR_SERVER;Database=YOUR_DATABASE;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "Ayora",
    "Audience": "Ayora",
    "SigningKey": "__SET_VIA_USER_SECRETS_OR_ENV__",
    "AccessTokenMinutes": 15,
    "PasswordResetTokenMinutes": 30
  },
  "RefreshTokens": {
    "DaysToLive": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5173",
      "http://localhost:5173"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
